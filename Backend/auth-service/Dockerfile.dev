# ── Dockerfile de Desenvolvimento ────────────────────────────
# Usado por todos os serviços NestJS em dev.
# O código fonte é montado via volume no docker-compose.dev.yml
# Hot-reload via "npm run start:dev"
# ─────────────────────────────────────────────────────────────
FROM node:20-alpine

WORKDIR /app

# Instala dependências (incluindo devDependencies)
COPY package*.json ./
RUN npm ci

# O código fonte vem do bind mount — não copiamos aqui.
# Apenas copiamos o entrypoint.
COPY entrypoint.dev.sh /usr/local/bin/entrypoint.dev.sh
RUN chmod +x /usr/local/bin/entrypoint.dev.sh

ENTRYPOINT ["entrypoint.dev.sh"]
CMD ["npm", "run", "start:dev"]
