FROM node:20-alpine AS base

RUN apk add --no-cache libc6-compat
WORKDIR /app
ENV NEXT_TELEMETRY_DISABLED=1

FROM base AS deps
COPY package.json package-lock.json ./
RUN npm install

FROM base AS builder
ARG NEXT_PUBLIC_API_URL=/api
ARG NEXT_PUBLIC_WS_URL=ws://localhost:3003
ARG NEXT_PUBLIC_WS_ENABLED=true
ARG NEXT_PUBLIC_FRONTEND_URL=http://localhost:3001
ARG NEXT_PUBLIC_PENDING_INVITATIONS_ENDPOINT=/invitations/pending
ARG NEXT_PUBLIC_DEBUG_INVITES=false
ARG NEXT_PUBLIC_DEBUG_LOGIN=false
ARG NEXT_PUBLIC_DEBUG_API_REQUESTS=false
ARG NEXT_PUBLIC_DEBUG_CAMPAIGN_DETAIL=false
ARG NEXT_PUBLIC_DEBUG_CAMPAIGN_IMAGE=false
ARG NEXT_PUBLIC_SILENCE_BACKEND_REQUESTS=false
ARG API_GATEWAY_INTERNAL_URL=http://api-gateway:3000
ENV NODE_ENV=production \
    NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL} \
    NEXT_PUBLIC_WS_URL=${NEXT_PUBLIC_WS_URL} \
    NEXT_PUBLIC_WS_ENABLED=${NEXT_PUBLIC_WS_ENABLED} \
    NEXT_PUBLIC_FRONTEND_URL=${NEXT_PUBLIC_FRONTEND_URL} \
    NEXT_PUBLIC_PENDING_INVITATIONS_ENDPOINT=${NEXT_PUBLIC_PENDING_INVITATIONS_ENDPOINT} \
    NEXT_PUBLIC_DEBUG_INVITES=${NEXT_PUBLIC_DEBUG_INVITES} \
    NEXT_PUBLIC_DEBUG_LOGIN=${NEXT_PUBLIC_DEBUG_LOGIN} \
    NEXT_PUBLIC_DEBUG_API_REQUESTS=${NEXT_PUBLIC_DEBUG_API_REQUESTS} \
    NEXT_PUBLIC_DEBUG_CAMPAIGN_DETAIL=${NEXT_PUBLIC_DEBUG_CAMPAIGN_DETAIL} \
    NEXT_PUBLIC_DEBUG_CAMPAIGN_IMAGE=${NEXT_PUBLIC_DEBUG_CAMPAIGN_IMAGE} \
    NEXT_PUBLIC_SILENCE_BACKEND_REQUESTS=${NEXT_PUBLIC_SILENCE_BACKEND_REQUESTS} \
    API_GATEWAY_INTERNAL_URL=${API_GATEWAY_INTERNAL_URL}
COPY --from=deps /app/node_modules ./node_modules
COPY . .
RUN npm run build

FROM base AS runner
ARG NEXT_PUBLIC_API_URL=/api
ARG NEXT_PUBLIC_WS_URL=ws://localhost:3003
ARG NEXT_PUBLIC_WS_ENABLED=true
ARG NEXT_PUBLIC_FRONTEND_URL=http://localhost:3001
ARG NEXT_PUBLIC_PENDING_INVITATIONS_ENDPOINT=/invitations/pending
ARG NEXT_PUBLIC_DEBUG_INVITES=false
ARG NEXT_PUBLIC_DEBUG_LOGIN=false
ARG NEXT_PUBLIC_DEBUG_API_REQUESTS=false
ARG NEXT_PUBLIC_DEBUG_CAMPAIGN_DETAIL=false
ARG NEXT_PUBLIC_DEBUG_CAMPAIGN_IMAGE=false
ARG NEXT_PUBLIC_SILENCE_BACKEND_REQUESTS=false
ARG API_GATEWAY_INTERNAL_URL=http://api-gateway:3000
ENV NODE_ENV=production \
    PORT=3001 \
    HOSTNAME=0.0.0.0 \
    NEXT_TELEMETRY_DISABLED=1 \
    NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL} \
    NEXT_PUBLIC_WS_URL=${NEXT_PUBLIC_WS_URL} \
    NEXT_PUBLIC_WS_ENABLED=${NEXT_PUBLIC_WS_ENABLED} \
    NEXT_PUBLIC_FRONTEND_URL=${NEXT_PUBLIC_FRONTEND_URL} \
    NEXT_PUBLIC_PENDING_INVITATIONS_ENDPOINT=${NEXT_PUBLIC_PENDING_INVITATIONS_ENDPOINT} \
    NEXT_PUBLIC_DEBUG_INVITES=${NEXT_PUBLIC_DEBUG_INVITES} \
    NEXT_PUBLIC_DEBUG_LOGIN=${NEXT_PUBLIC_DEBUG_LOGIN} \
    NEXT_PUBLIC_DEBUG_API_REQUESTS=${NEXT_PUBLIC_DEBUG_API_REQUESTS} \
    NEXT_PUBLIC_DEBUG_CAMPAIGN_DETAIL=${NEXT_PUBLIC_DEBUG_CAMPAIGN_DETAIL} \
    NEXT_PUBLIC_DEBUG_CAMPAIGN_IMAGE=${NEXT_PUBLIC_DEBUG_CAMPAIGN_IMAGE} \
    NEXT_PUBLIC_SILENCE_BACKEND_REQUESTS=${NEXT_PUBLIC_SILENCE_BACKEND_REQUESTS} \
    API_GATEWAY_INTERNAL_URL=${API_GATEWAY_INTERNAL_URL}
RUN addgroup -S nodejs && adduser -S nextjs -G nodejs
COPY --from=builder /app/public ./public
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
USER nextjs
EXPOSE 3001
CMD ["node", "server.js"]
