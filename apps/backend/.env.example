# ══════════════════════════════════════════════════════════════
# ft_transcendence — Environment Variables
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# NEVER commit the .env file to version control.
#
# Passwords and secrets are stored as Docker Secrets in:
#   secrets/*.txt
# ══════════════════════════════════════════════════════════════

# ──────────────────────────────────────────
# GLOBAL
# ──────────────────────────────────────────
NODE_ENV=production
JWT_EXPIRATION=3600

# ──────────────────────────────────────────
# API GATEWAY
# ──────────────────────────────────────────
API_GATEWAY_PORT=3000

# ──────────────────────────────────────────
# AUTH SERVICE + DATABASE
# ──────────────────────────────────────────
AUTH_SERVICE_PORT=3001
AUTH_DB_HOST=authDb
AUTH_DB_PORT=5432
AUTH_DB_NAME=auth
AUTH_DB_USER=auth_user
# AUTH_DB_PASSWORD → secrets/auth_db_password.txt

# ──────────────────────────────────────────
# CAMPAIGN SERVICE + DATABASE
# ──────────────────────────────────────────
CAMPAIGN_SERVICE_PORT=3002
CAMPAIGN_DB_HOST=campaignDb
CAMPAIGN_DB_PORT=5432
CAMPAIGN_DB_NAME=campaign
CAMPAIGN_DB_USER=campaign_user
# CAMPAIGN_DB_PASSWORD → secrets/campaign_db_password.txt

# ──────────────────────────────────────────
# NOTIFICATION SERVICE + DATABASE
# ──────────────────────────────────────────
NOTIFICATION_SERVICE_PORT=3003
NOTIFICATION_DB_HOST=notificationDb
NOTIFICATION_DB_PORT=5432
NOTIFICATION_DB_NAME=notification
NOTIFICATION_DB_USER=notification_user
# NOTIFICATION_DB_PASSWORD → secrets/notification_db_password.txt

# SMTP Configuration for Email (2FA, notifications)
# Leave empty or commented to disable email sending (logs only)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@ft-transcendence.com

# ──────────────────────────────────────────
# USER SERVICE + DATABASE
# ──────────────────────────────────────────
USER_SERVICE_PORT=3004
USER_DB_HOST=userDb
USER_DB_PORT=5432
USER_DB_NAME=users
USER_DB_USER=user_user
# USER_DB_PASSWORD → secrets/user_db_password.txt

# ──────────────────────────────────────────
# WALLET SERVICE + DATABASE
# ──────────────────────────────────────────
WALLET_SERVICE_PORT=3005
WALLET_DB_HOST=walletDb
WALLET_DB_PORT=5432
WALLET_DB_NAME=wallet
WALLET_DB_USER=wallet_user
# WALLET_DB_PASSWORD → secrets/wallet_db_password.txt


# ──────────────────────────────────────────
# LEDGER SERVICE + DATABASE
# ──────────────────────────────────────────
LEDGER_SERVICE_PORT=3006
LEDGER_DB_HOST=ledgerDb
LEDGER_DB_PORT=5432
LEDGER_DB_NAME=ledger
LEDGER_DB_USER=ledger_user
AVALANCHE_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
VAKS_CONTRACT_ADDRESS=     # preencher após deploy

metamask_private_key=8fce425bed92ac5c26d6c394f6249d67016874100cddb82b9327a4ebbf129934
```

---

### Ordem de implementação
```
1. npm install no ledger-contracts → npx hardhat test (todos devem passar)
2. Obter AVAX de testnet no faucet.avax.network
3. npx hardhat run scripts/deploy.ts --network fuji
4. Copiar o endereço → VAKS_CONTRACT_ADDRESS no .env
5. npm install no ledger-service
6. npx prisma generate && npx prisma migrate dev
7. docker compose -f docker-compose.dev.yml up -d ledgerDb redis
8. npm run start:dev no ledger-service


# ──────────────────────────────────────────
